{
  "name": "weekly-health",
  "description": "Weekly product health readout: signup and engagement trends, the solo activation funnel, and automated mining of what is currently blocking first uploads.",
  "params": {"funnel_days": "28"},
  "tasks": [
    {
      "id": 1,
      "tool": "insight_query",
      "args": {"events": ["account_created"], "metric": "unique_users", "by_week": true, "timeframe_days": 56},
      "depends_on": []
    },
    {
      "id": 2,
      "tool": "insight_query",
      "args": {"events": ["file_uploaded", "link_shared", "comment_added"], "metric": "unique_users", "by_week": true, "timeframe_days": 56},
      "depends_on": []
    },
    {
      "id": 3,
      "tool": "funnel_analysis",
      "args": {"steps": ["workspace_created", "file_uploaded", "link_shared"], "timeframe_days": "$funnel_days"},
      "depends_on": []
    },
    {
      "id": 4,
      "tool": "funnel_breakdown",
      "args": {"steps": ["workspace_created", "file_uploaded"], "timeframe_days": "$funnel_days"},
      "depends_on": []
    }
  ]
}
