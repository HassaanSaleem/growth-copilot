# Copy to .env and fill in. Everything has a working default except the API key,
# and even that is optional: recipe runs (`growth-copilot recipe ...`) are fully
# deterministic and never call an LLM.

# Anthropic API key — required only for `ask` (LLM planning + synthesis).
ANTHROPIC_API_KEY=

# Model overrides (all default to claude-opus-4-8).
# Drop triage to a lighter model to cut cost, e.g. claude-haiku-4-5.
GROWTH_COPILOT_MODEL=
GROWTH_COPILOT_TRIAGE_MODEL=
GROWTH_COPILOT_PLANNER_MODEL=
GROWTH_COPILOT_SYNTHESIS_MODEL=

# Paths (defaults shown).
GROWTH_COPILOT_DB=data/warehouse.duckdb
GROWTH_COPILOT_CHECKPOINTS=data/checkpoints.sqlite
